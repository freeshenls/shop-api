<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <style>
    body {
      font-family: Arial, sans-serif;
      line-height: 1.6;
      color: #333333;
      background-color: #f8fafc;
      padding: 20px;
    }
    .container {
      max-width: 600px;
      margin: 0 auto;
      background: #ffffff;
      border: 1px solid #e2e8f0;
      border-radius: 8px;
      padding: 30px;
      box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    }
    h2 {
      font-size: 20px;
      font-weight: 700;
      color: #0f172a;
      border-bottom: 2px solid #3b82f6;
      padding-bottom: 10px;
      margin-top: 0;
    }
    .product-info {
      background-color: #eff6ff;
      border-left: 4px solid #3b82f6;
      padding: 15px;
      margin-bottom: 20px;
      border-radius: 0 4px 4px 0;
    }
    .field-row {
      margin-bottom: 12px;
      display: flex;
      border-bottom: 1px dashed #e2e8f0;
      padding-bottom: 8px;
    }
    .field-label {
      width: 150px;
      font-weight: bold;
      color: #475569;
    }
    .field-value {
      flex: 1;
      color: #0f172a;
    }
    .comments-box {
      background-color: #f1f5f9;
      padding: 15px;
      border-radius: 4px;
      margin-top: 20px;
      font-style: italic;
    }
  </style>
</head>
<body>
  <div class="container">
    <h2>New Request Info Inquiry Received</h2>

    <div class="product-info">
      <strong>Product Requested:</strong> <%= @product.title %><br>
      <strong>SKU:</strong> sku#<%= @product.sku.to_s.gsub(/^CPN-/, '') %><br>
      <strong>Link:</strong> <a href="<%= "https://gosyphor.com/products/#{@product.slug}" %>" target="_blank">View Details Page</a>
    </div>

    <div class="field-row">
      <div class="field-label">First Name:</div>
      <div class="field-value"><%= @inquiry.first_name %></div>
    </div>
    <div class="field-row">
      <div class="field-label">Last Name:</div>
      <div class="field-value"><%= @inquiry.last_name %></div>
    </div>
    <div class="field-row">
      <div class="field-label">Company Name:</div>
      <div class="field-value"><%= @inquiry.company_name %></div>
    </div>
    <div class="field-row">
      <div class="field-label">Email:</div>
      <div class="field-value"><%= @inquiry.email %></div>
    </div>
    <div class="field-row">
      <div class="field-label">Phone Number:</div>
      <div class="field-value"><%= @inquiry.phone %></div>
    </div>
    <div class="field-row">
      <div class="field-label">Country/Region:</div>
      <div class="field-value"><%= @inquiry.country %></div>
    </div>
    <div class="field-row">
      <div class="field-label">Quantity:</div>
      <div class="field-value"><%= @inquiry.quantity %></div>
    </div>
    <div class="field-row">
      <div class="field-label">Preferred Colors:</div>
      <div class="field-value"><%= @inquiry.color %></div>
    </div>
    <div class="field-row">
      <div class="field-label">Date Required:</div>
      <div class="field-value"><%= @inquiry.date_required %></div>
    </div>

    <% if @inquiry.artwork_file.attached? %>
      <div class="field-row" style="background-color: #f0fdf4; border-left: 4px solid #22c55e; padding: 10px 15px; border-radius: 0 4px 4px 0; margin-top: 15px;">
        <strong>Artwork Attached:</strong> Yes (<%= @inquiry.artwork_file.filename.to_s %>)
      </div>
    <% end %>

    <% if @inquiry.comments.present? %>
      <div class="comments-box">
        <strong>Comments / Special Instructions:</strong><br>
        <%= simple_format(@inquiry.comments) %>
      </div>
    <% end %>
  </div>
</body>
</html>
